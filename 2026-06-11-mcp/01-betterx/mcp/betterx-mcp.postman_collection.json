{
  "info": {
    "name": "BetterX MCP",
    "description": "Test the BetterX MCP server (stateful Streamable HTTP on /mcp).\n\n**Setup**\n1. Set collection variables `baseUrl` (default http://localhost:3005) and `jwt` (from backend `POST /auth/login`).\n2. Run requests in the **Session** folder in order — Initialize stores `mcpSessionId` from the response header.\n3. Then run any request in **Tools**.\n\nResponses use Server-Sent Events (`event: message` / `data: {...}`). The JSON-RPC result is in the `data` line.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3005"
    },
    {
      "key": "jwt",
      "value": ""
    },
    {
      "key": "mcpSessionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Session",
      "item": [
        {
          "name": "MCP - Initialize",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const sessionId = pm.response.headers.get('mcp-session-id');",
                  "if (sessionId) {",
                  "    pm.collectionVariables.set('mcpSessionId', sessionId);",
                  "    console.log('Saved mcpSessionId:', sessionId);",
                  "}",
                  "pm.test('initialize returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('mcp-session-id header present', () => pm.expect(sessionId).to.be.a('string').and.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"2024-11-05\",\n    \"capabilities\": {},\n    \"clientInfo\": {\n      \"name\": \"postman\",\n      \"version\": \"1.0.0\"\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/mcp"
          }
        },
        {
          "name": "MCP - Initialized notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"notifications/initialized\"\n}"
            },
            "url": "{{baseUrl}}/mcp"
          }
        },
        {
          "name": "MCP - tools/list",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}"
            },
            "url": "{{baseUrl}}/mcp"
          }
        },
        {
          "name": "MCP - GET /mcp (SSE stream)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "url": "{{baseUrl}}/mcp"
          }
        },
        {
          "name": "MCP - DELETE session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "url": "{{baseUrl}}/mcp"
          }
        }
      ]
    },
    {
      "name": "Tools",
      "item": [
        {
          "name": "MCP - Ping tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 3,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"ping\",\n    \"arguments\": {}\n  }\n}"
            },
            "url": "{{baseUrl}}/mcp"
          }
        },
        {
          "name": "MCP - getFollowing tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 4,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"getFollowing\",\n    \"arguments\": {}\n  }\n}"
            },
            "url": "{{baseUrl}}/mcp"
          }
        },
        {
          "name": "MCP - getFollowers tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 5,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"getFollowers\",\n    \"arguments\": {}\n  }\n}"
            },
            "url": "{{baseUrl}}/mcp"
          }
        },
        {
          "name": "MCP - follow tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json, text/event-stream"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Mcp-Session-Id",
                "value": "{{mcpSessionId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 6,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"follow\",\n    \"arguments\": {\n      \"followeeId\": \"PASTE_USER_ID_HERE\"\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/mcp"
          }
        }
      ]
    }
  ]
}
